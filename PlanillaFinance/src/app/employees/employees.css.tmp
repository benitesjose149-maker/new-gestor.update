:host {
    display: block;
    padding: 2rem;
    background-color: #f9fafb;
    min-height: 100vh;
}

@media (max-width: 768px) {
    :host {
        padding: 1rem;
    }
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
}

@media (max-width: 640px) {
    .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }

    .add-btn {
        width: 100%;
        text-align: center;
    }
}

.page-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 0;
}

.add-btn {
    background-color: #2563eb;
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
}

.add-btn:hover {
    background-color: #1d4ed8;
}

.controls-bar {
    margin-bottom: 1.5rem;
}

.search-box {
    position: relative;
    max-width: 400px;
}

.search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #9ca3af;
}

.search-box input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.5rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
}

.search-box input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.table-container {
    background-color: white;
    border-radius: 12px;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    overflow-x: auto;
}

.employees-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
}

.employees-table th {
    background-color: #f9fafb;
    color: #6b7280;
    font-weight: 600;
    text-align: left;
    padding: 1rem 1.5rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #e5e7eb;
}

.employees-table td {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #f3f4f6;
    color: #374151;
    font-size: 0.95rem;
}

.employees-table tr:last-child td {
    border-bottom: none;
}

.user-info {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.avatar {
    width: 40px;
    height: 40px;
    background-color: #e0e7ff;
    color: #4338ca;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-weight: 700;
    font-size: 1rem;
}

.user-info .font-medium {
    display: block;
    font-weight: 600;
    color: #111827;
}

.user-info .text-sm {
    display: block;
    font-size: 0.85rem;
    color: #6b7280;
}

.badge {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    display: inline-block;
}

.badge.department {
    background-color: #f3f4f6;
    color: #374151;
}

.badge.status.active {
    background-color: #d1fae5;
    color: #065f46;
}

.badge.status.inactive {
    background-color: #fee2e2;
    color: #991b1b;
}

.actions {
    display: flex;
    gap: 0.5rem;
}

.icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0.25rem;
    border-radius: 4px;
    transition: background-color 0.2s;
}

.icon-btn:hover {
    background-color: #f3f4f6;
}

.no-data {
    text-align: center;
    padding: 3rem;
    color: #6b7280;
}

.modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.modal-content {
    background-color: white;
    border-radius: 12px;
    width: 100%;
    max-width: 800px;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    overflow: hidden;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
}

.modal-body {
    padding: 1.5rem;
    overflow-y: auto;
}

h3 {
    font-size: 1.1rem;
    color: #2563eb;
    margin: 1.5rem 0 1rem;
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 0.5rem;
}

h3:first-child {
    margin-top: 0;
}

.input-group {
    display: flex;
    gap: 0.5rem;
}

.search-btn {
    background-color: #2563eb;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0 1rem;
    cursor: pointer;
    font-size: 1.2rem;
}

.checkbox-group {
    display: flex;
    align-items: center;
    height: 100%;
    padding-top: 1.5rem;
}

.checkbox-group label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    margin: 0;
}

.checkbox-group input {
    width: auto;
}

.modal-header {
    padding: 1.5rem;
    background-color: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-header h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: #111827;
}

.close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: #6b7280;
    cursor: pointer;
}

.modal-body {
    padding: 1.5rem;
}

.form-group {
    margin-bottom: 1.25rem;
}

.form-group label {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    color: #374151;
    margin-bottom: 0.5rem;
}

.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.95rem;
    outline: none;
}

.form-group input:focus,
.form-group select:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.1);
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

@media (max-width: 640px) {
    .form-row {
        grid-template-columns: 1fr;
    }

    .modal-content {
        width: 95%;
        margin: 10px;
    }
}

.modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 1.5rem;
    padding: 1.5rem;
    background-color: #f9fafb;
    border-top: 1px solid #e5e7eb;
}

.btn-cancel {
    background: white;
    border: 1px solid #d1d5db;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 500;
    color: #4b5563;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-cancel:hover {
    background-color: #f3f4f6;
    border-color: #9ca3af;
}

.btn-save {
    background-color: #2563eb;
    color: white;
    border: none;
    padding: 0.75rem 2.5rem;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.95rem;
    box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-save:hover {
    background-color: #1d4ed8;
    box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.3);
    transform: translateY(-2px);
}

.btn-save:active {
    transform: translateY(0);
}

.btn-action {
    border: 1px solid #e5e7eb;
    background-color: white;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    margin-right: 0.5rem;
    color: #4b5563;
}

.btn-action:hover {
    background-color: #f9fafb;
    border-color: #d1d5db;
}

.btn-action.view {
    color: #0369a1;
    background-color: #f0f9ff;
    border-color: #bae6fd;
}

.btn-action.view:hover {
    background-color: #e0f2fe;
    border-color: #7dd3fc;
}

.btn-action.edit {
    color: #374151;
    background-color: #f3f4f6;
    border-color: #e5e7eb;
}

.btn-action.edit:hover {
    background-color: #e5e7eb;
    border-color: #d1d5db;
}

.btn-action.delete {
    color: #b91c1c;
    background-color: #fef2f2;
    border-color: #fecaca;
}

.btn-action.delete:hover {
    background-color: #fee2e2;
    border-color: #fca5a5;
}

/* Styles for aligned checkbox below input */
.form-group-checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
}

.form-group-checkbox input[type="checkbox"] {
    width: auto;
    margin: 0;
    cursor: pointer;
    accent-color: #2563eb;
    width: 16px;
    height: 16px;
}

.form-group-checkbox label {
    margin: 0;
    font-size: 0.85rem;
    color: #4b5563;
    font-weight: 500;
    cursor: pointer;
}

.form-group-checkbox.small-text label {
    font-size: 0.8rem;
    color: #6b7280;
}

/* Invalid Field Validation */
.form-control.invalid-field {
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 1px #ef4444 !important;
    background-color: #fef2f2 !important;
}

/* DNI Search Styling */
.dni-input-container {
    display: flex;
    gap: 8px;
    align-items: center;
}

.dni-input-container .form-control {
    flex: 1;
}

.btn-search {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    white-space: nowrap;
    height: 42px;
    /* Matching form-control height approximately */
    box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2);
}

.btn-search:hover:not(:disabled) {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px rgba(37, 99, 235, 0.3);
}

.btn-search:active:not(:disabled) {
    transform: translateY(0);
}

.btn-search:disabled {
    background: #94a3b8;
    cursor: not-allowed;
    box-shadow: none;
}

.searching-spinner {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
}

.form-control.invalid-field:focus {
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2) !important;
}

/* Notification Modal */
.notif-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.3);
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 80px;
    z-index: 9999;
    animation: fadeIn 0.2s ease;
}

.notif-box {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.75rem;
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    animation: slideDown 0.3s ease;
    min-width: 320px;
    max-width: 500px;
}

.notif-success {
    background-color: #f0fdf4;
    border: 1px solid #86efac;
}

.notif-error {
    background-color: #fef2f2;
    border: 1px solid #fca5a5;
}

.notif-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
}

.notif-message {
    font-size: 0.95rem;
    font-weight: 500;
    color: #111827;
    flex: 1;
}

.notif-close {
    background: none;
    border: none;
    font-size: 1.4rem;
    color: #9ca3af;
    cursor: pointer;
    padding: 0 0.25rem;
    flex-shrink: 0;
    transition: color 0.2s;
}

.notif-close:hover {
    color: #374151;
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Leave Modal Specific Styles */
.leave-modal {
    max-width: 500px;
}

.btn-danger {
    background: linear-gradient(135deg, #ff4c4c 0%, #dc2626 100%) !important;
}

.btn-danger:hover {
    box-shadow: 0 4px 15px rgba(220, 38, 38, 0.4) !important;
    transform: translateY(-2px);
}

.mt-4 {
    margin-top: 1.5rem;
}

textarea.form-control {
    width: 100%;
    resize: none !important;
    border-radius: 10px !important;
    padding: 12px !important;
}
